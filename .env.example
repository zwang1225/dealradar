# Connection string for the Postgres (Neon) database, provisioned from the
# Vercel dashboard's Storage tab. Copy the real value into .env.local
# (gitignored) -- never commit the actual connection string.
DATABASE_URL=

# Only needed to test scripts/notify.mjs locally (the daily LLM-picks +
# email script). In production these live as GitHub Actions repository
# secrets, not Vercel env vars -- notify.mjs is run by CI, not Next.js.
OPENAI_API_KEY=
# No default on purpose -- pick whatever's current at platform.openai.com
# when you set this up.
OPENAI_MODEL=
RESEND_API_KEY=
# Must be a sending address Resend will actually let you send from --
# either a verified domain or whatever Resend's current sandbox sender allows.
RESEND_FROM=

# Only needed to test scripts/fetch-bestbuy-deals.mjs locally. Requires a
# custom-domain email to register -- see docs/roadmap.md.
BESTBUY_API_KEY=
